# Meclis Istihbarat Sistemi - Environment Variables
# Copy this file to .env and update values

# Environment
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=sqlite:///./data/meclis.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/meclis

# Ollama LLM
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_FALLBACK_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=300

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB
CHROMA_PATH=./chroma_db

# Scraping
MAX_TWEETS_PER_USER=500
DAYS_BACK=90
SCRAPE_TIMEOUT=30
HEADLESS_BROWSER=false

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Cache
CACHE_TTL=300
REPORT_CACHE_HOURS=168
